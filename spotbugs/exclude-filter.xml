<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter
        xmlns="https://github.com/spotbugs/filter/3.0.0"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0 https://raw.githubusercontent.com/spotbugs/spotbugs/master/spotbugs/etc/findbugsfilter.xsd">

    <!--
      CT_CONSTRUCTOR_THROW: excluded for JPA @Entity classes only.

      The finalizer attack this detector guards against requires a subclass to override finalize().
      Since Java 9, the JVM does not invoke a finalizer if the constructor throws before
      Object.<init> exits, making this attack vector moot on Java 21.

      Additionally, JPA entities cannot be declared final because Hibernate requires
      non-final classes to generate lazy-loading proxies, and the deprecated finalize()
      approach is not acceptable on Java 21.

      References:
      - https://github.com/spotbugs/spotbugs/issues/2710
      - https://github.com/spotbugs/spotbugs/issues/3417
      - https://wiki.sei.cmu.edu/confluence/display/java/OBJ11-J.+Be+wary+of+letting+constructors+throw+exceptions
    -->
    <Match>
        <Package name="~com\.ebikes\.notifications\.database\.entities"/>
        <Bug pattern="CT_CONSTRUCTOR_THROW"/>
    </Match>

    <!--
      EI_EXPOSE_REP / EI_EXPOSE_REP2: excluded for response and internal DTO packages.

      These are outbound read-only snapshots and internal pipeline objects constructed
      by mappers within the application boundary. No external party mutates these
      collections after construction, so defensive copies add allocation overhead
      with no security benefit.

      Additionally, SpotBugs fires these as false positives on Java records even when
      List.copyOf() is used in a compact constructor (confirmed bug):
      - https://github.com/spotbugs/spotbugs/issues/3022
      - https://github.com/spotbugs/spotbugs/issues/1771

      Request DTOs (external input) are fixed in code with defensive copies instead.
    -->
    <Match>
        <Package name="~com\.ebikes\.notifications\.dtos\.responses\..+"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>

    <Match>
        <Package name="~com\.ebikes\.notifications\.dtos\.internal(\..+)?"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>

    <!--
      EI_EXPOSE_REP2: excluded for JPA entity @ManyToOne / @OneToMany association fields.

      SpotBugs flags storing an externally passed object by reference as a potential
      representation exposure. For JPA-managed entity associations this is a false positive:
      defensive copying would detach the object from the Hibernate persistence context,
      breaking lazy loading, dirty checking, and identity map semantics.
    -->
    <Match>
        <Package name="~com\.ebikes\.notifications\.database\.entities"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!--
      EI_EXPOSE_REP2: excluded for channel adapter constructors.

      NotificationProperties is a Spring-managed singleton owned by the container.
      ObjectMapper in Jackson 3 is fully immutable by design — no mutating methods
      exist after construction. Both warnings are false positives in this context.
    -->
    <Match>
        <Or>
            <Class name="com.ebikes.notifications.adapters.channels.sms.TaifaMobileSmsAdapter"/>
            <Class name="com.ebikes.notifications.adapters.channels.whatsapp.MetaWhatsAppAdapter"/>
        </Or>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!--
      NP_NULL_ON_SOME_PATH: false positive on MapStruct-generated mapper implementations.

      MapStruct generates a null guard at the top of each mapping method that returns
      null immediately if the source parameter is null. SpotBugs does not correctly
      model the control flow after this guard and incorrectly reports that fields of
      the source parameter may be dereferenced on the null path. The generated code
      is safe — the dereference is never reached when context is null.
    -->
    <Match>
        <Class name="com.ebikes.notifications.mappers.WhatsAppMapperImpl"/>
        <Bug pattern="NP_NULL_ON_SOME_PATH"/>
    </Match>

    <!--
      SE_BAD_FIELD: excluded for JPA entity classes.

      SpotBugs fires this when a class in a Serializable hierarchy contains a field
      whose type does not implement Serializable. JPA entities inherit Serializable
      from a Spring Data base class (required for detached entity transport), but
      embedded value objects mapped as jsonb columns (e.g. Address, DaySchedule)
      do not need to implement Serializable because Java serialization is never
      used in the Hibernate/jsonb persistence path.
    -->
    <Match>
        <Package name="~com\.ebikes\.notifications\.database\.entities"/>
        <Bug pattern="SE_BAD_FIELD"/>
    </Match>

    <!--
      EI_EXPOSE_REP2: false positive on Spring-managed collaborator injection.

      SpotBugs flags storing an injected RestClient by reference as representation
      exposure. RestClient is a Spring-managed interface with no externally mutable
      state — defensive copying is neither meaningful nor possible for interface types.
    -->
    <Match>
        <Or>
            <Class name="com.ebikes.notifications.adapters.iam.IamServiceAdapter"/>
            <Class name="com.ebikes.notifications.adapters.organizations.OrganizationsServiceAdapter"/>
        </Or>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!--
      EI_EXPOSE_REP2: false positive on Spring-managed singleton injection.

      RedisTemplate is a Spring-managed infrastructure bean holding connection pool state —
      it cannot be defensively copied and must be shared. UserPreferenceService is a
      Spring-managed @Service; storing a collaborator by reference is the standard injection
      pattern and the type carries no mutable representation that the caller could corrupt.
    -->
    <Match>
        <Or>
            <Class name="com.ebikes.notifications.services.cache.IamCacheService"/>
            <Class name="com.ebikes.notifications.services.cache.OrganizationsCacheService"/>
            <Class name="com.ebikes.notifications.services.notifications.MessageProcessor"/>
        </Or>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

</FindBugsFilter>
