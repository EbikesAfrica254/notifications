<?xml version="1.0"?>
<!DOCTYPE import-control PUBLIC
        "-//Checkstyle//DTD ImportControl Configuration 1.4//EN"
        "https://checkstyle.org/dtds/import_control_1_4.dtd">

<import-control pkg="com.ebikes.notifications" strategyOnMismatch="allowed">

    <!--
      Intentionally lean policy.

      Goal:
      - enforce only high-value layering boundaries
      - avoid default-deny breakage across a single Spring Boot services
      - let Spotless / ImportOrder handle formatting concerns separately
    -->

    <!-- ========================================================= -->
    <!-- CONTROLLERS                                                -->
    <!-- ========================================================= -->

    <subpackage name="controllers" strategyOnMismatch="allowed">
        <disallow pkg="com.ebikes.notifications.database.entities"/>
        <disallow pkg="com.ebikes.notifications.database.entities.bases"/>
        <disallow pkg="com.ebikes.notifications.database.repositories"/>
        <disallow pkg="com.ebikes.notifications.database.specifications"/>
        <disallow pkg="com.ebikes.notifications.listeners"/>
        <disallow pkg="com.ebikes.notifications.publishers"/>
        <disallow pkg="com.ebikes.notifications.adapters"/>
    </subpackage>

    <!-- ========================================================= -->
    <!-- DATABASE                                                   -->
    <!-- ========================================================= -->

    <subpackage name="database.repositories" strategyOnMismatch="allowed">
        <disallow pkg="com.ebikes.notifications.controllers"/>
        <disallow pkg="com.ebikes.notifications.services"/>
        <disallow pkg="com.ebikes.notifications.listeners"/>
        <disallow pkg="com.ebikes.notifications.publishers"/>
        <disallow pkg="com.ebikes.notifications.adapters"/>
        <disallow pkg="com.ebikes.notifications.mappers"/>
    </subpackage>

    <subpackage name="database.specifications" strategyOnMismatch="allowed">
        <disallow pkg="com.ebikes.notifications.controllers"/>
        <disallow pkg="com.ebikes.notifications.services"/>
        <disallow pkg="com.ebikes.notifications.listeners"/>
        <disallow pkg="com.ebikes.notifications.publishers"/>
        <disallow pkg="com.ebikes.notifications.adapters"/>
        <disallow pkg="com.ebikes.notifications.mappers"/>
    </subpackage>

    <subpackage name="database.entities" strategyOnMismatch="allowed">
        <disallow pkg="com.ebikes.notifications.controllers"/>
        <disallow pkg="com.ebikes.notifications.services"/>
        <disallow pkg="com.ebikes.notifications.listeners"/>
        <disallow pkg="com.ebikes.notifications.publishers"/>
    </subpackage>

    <subpackage name="database.entities.bases" strategyOnMismatch="allowed">
        <disallow pkg="com.ebikes.notifications.controllers"/>
        <disallow pkg="com.ebikes.notifications.services"/>
        <disallow pkg="com.ebikes.notifications.listeners"/>
        <disallow pkg="com.ebikes.notifications.publishers"/>
    </subpackage>

    <!-- ========================================================= -->
    <!-- DOMAIN                                                     -->
    <!-- ========================================================= -->

    <subpackage name="domain" strategyOnMismatch="allowed">
        <disallow pkg="com.ebikes.notifications.controllers"/>
        <disallow pkg="com.ebikes.notifications.database.repositories"/>
        <disallow pkg="com.ebikes.notifications.database.specifications"/>
        <disallow pkg="com.ebikes.notifications.services"/>
        <disallow pkg="com.ebikes.notifications.listeners"/>
        <disallow pkg="com.ebikes.notifications.publishers"/>
        <disallow pkg="com.ebikes.notifications.adapters"/>
        <disallow pkg="com.ebikes.notifications.configurations"/>
        <disallow pkg="org.springframework"/>
    </subpackage>

    <!-- ========================================================= -->
    <!-- ADAPTERS                                                   -->
    <!-- ========================================================= -->

    <subpackage name="adapters" strategyOnMismatch="allowed">
        <disallow pkg="com.ebikes.notifications.controllers"/>
        <disallow pkg="com.ebikes.notifications.database.repositories"/>
        <disallow pkg="com.ebikes.notifications.database.specifications"/>
        <disallow pkg="com.ebikes.notifications.listeners"/>
        <disallow pkg="com.ebikes.notifications.publishers"/>
    </subpackage>

    <!-- ========================================================= -->
    <!-- LISTENERS / PUBLISHERS                                     -->
    <!-- ========================================================= -->

    <subpackage name="listeners" strategyOnMismatch="allowed">
        <disallow pkg="com.ebikes.notifications.controllers"/>
        <disallow pkg="com.ebikes.notifications.database.repositories"/>
        <disallow pkg="com.ebikes.notifications.database.specifications"/>
        <disallow pkg="com.ebikes.notifications.database.entities"/>
        <disallow pkg="com.ebikes.notifications.database.entities.bases"/>
        <disallow pkg="com.ebikes.notifications.services.pricing"/>
        <disallow pkg="com.ebikes.notifications.services.notifications"/>
        <disallow pkg="com.ebikes.notifications.mappers"/>
        <disallow pkg="com.ebikes.notifications.adapters"/>
    </subpackage>

    <subpackage name="publishers" strategyOnMismatch="allowed">
        <disallow pkg="com.ebikes.notifications.controllers"/>
        <disallow pkg="com.ebikes.notifications.database.repositories"/>
        <disallow pkg="com.ebikes.notifications.database.specifications"/>
        <disallow pkg="com.ebikes.notifications.database.entities"/>
        <disallow pkg="com.ebikes.notifications.database.entities.bases"/>
        <disallow pkg="com.ebikes.notifications.listeners"/>
        <disallow pkg="com.ebikes.notifications.mappers"/>
        <disallow pkg="com.ebikes.notifications.adapters"/>
    </subpackage>

    <!-- ========================================================= -->
    <!-- SUPPORT                                                    -->
    <!-- ========================================================= -->

    <subpackage name="support.context" strategyOnMismatch="allowed">
        <disallow pkg="com.ebikes.notifications.controllers"/>
        <disallow pkg="com.ebikes.notifications.database.repositories"/>
        <disallow pkg="com.ebikes.notifications.database.specifications"/>
        <disallow pkg="com.ebikes.notifications.services"/>
        <disallow pkg="com.ebikes.notifications.listeners"/>
        <disallow pkg="com.ebikes.notifications.publishers"/>
    </subpackage>

    <subpackage name="support.references" strategyOnMismatch="allowed">
        <disallow pkg="com.ebikes.notifications.controllers"/>
        <disallow pkg="com.ebikes.notifications.database.repositories"/>
        <disallow pkg="com.ebikes.notifications.database.specifications"/>
        <disallow pkg="com.ebikes.notifications.services"/>
        <disallow pkg="com.ebikes.notifications.listeners"/>
        <disallow pkg="com.ebikes.notifications.publishers"/>
        <disallow pkg="org.springframework"/>
    </subpackage>

    <subpackage name="support.database" strategyOnMismatch="allowed">
        <disallow pkg="com.ebikes.notifications.controllers"/>
        <disallow pkg="com.ebikes.notifications.services"/>
        <disallow pkg="com.ebikes.notifications.database.repositories"/>
        <disallow pkg="com.ebikes.notifications.listeners"/>
        <disallow pkg="com.ebikes.notifications.publishers"/>
    </subpackage>

    <subpackage name="support.security" strategyOnMismatch="allowed">
        <disallow pkg="com.ebikes.notifications.controllers"/>
        <disallow pkg="com.ebikes.notifications.database.repositories"/>
        <disallow pkg="com.ebikes.notifications.database.specifications"/>
        <disallow pkg="com.ebikes.notifications.services"/>
        <disallow pkg="com.ebikes.notifications.listeners"/>
        <disallow pkg="com.ebikes.notifications.publishers"/>
    </subpackage>

</import-control>