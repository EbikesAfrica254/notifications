<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suppressions PUBLIC
        "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
        "https://checkstyle.org/dtds/suppressions_1_2.dtd">

<suppressions>
    <!-- formatter-friendly exceptions for annotated records / DTO signatures -->
    <suppress
            checks="LineLength"
            files=".*/src/main/java/com/ebikes/notifications/dtos/(requests|responses)/.*\.java"/>

    <!-- @AssertTrue message strings on entity cross-field validators cannot be
         wrapped by Google Java Format — string literals are never split -->
    <suppress
            checks="LineLength"
            files=".*/src/main/java/com/ebikes/notifications/database/entities/.*\.java"/>

    <!-- generated sources -->
    <suppress checks=".*" files=".*/target/generated-sources/.*"/>
    <suppress checks=".*" files=".*/target/generated-test-sources/.*"/>
</suppressions>